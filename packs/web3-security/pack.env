# Pack config — web3-security (a real, filled-in example pack).

PACK_NAME="Web3 Security Research"
PACK_DESC="Mines smart-contract / DeFi / chain security research into a structured library."

OUTPUT_DIR="output"

# Web grounding ON — security work needs real, current sources, not model memory.
WEB_GROUNDING="true"

# Rank these high-authority security/research domains first.
SEARCH_PREFERRED_DOMAINS="arxiv.org eprint.iacr.org trailofbits openzeppelin cyfrin chain.link eips.ethereum.org rekt.news blocksec slowmist code4rena sherlock immunefi dedaub spearbit samczsun scsfg.io swcregistry"

# Drop these (junk for security research).
SEARCH_BLOCK_DOMAINS="merriam-webster smartsheet investopedia.com/terms"
