# Pack config — reentrancy-fix-demo
# A tiny 3-phase demo: research a known bug -> design the fix -> implement it.
# Used to verify the fleet end-to-end on both Claude and Ollama.

PACK_NAME="Reentrancy Fix Demo (3-phase)"
PACK_DESC="Mini demo: research the reentrancy vuln, design the fix, implement the patched contract."

OUTPUT_DIR="output"

# Off for the mini run so it's fast and provider-symmetric (Claude uses its own
# search; Ollama works from knowledge — reentrancy is well documented). Flip to
# true + run with --profile grounding to exercise the cached web research path.
WEB_GROUNDING="false"

SEARCH_PREFERRED_DOMAINS="consensys openzeppelin swcregistry trailofbits cyfrin"
SEARCH_BLOCK_DOMAINS=""
