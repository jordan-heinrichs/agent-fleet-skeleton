# Pack config — sourced by the manager and workers.
# A "pack" is a self-contained topic plugin. Swap ACTIVE_PACK in .env to
# retarget the whole fleet at a different domain without touching the engine.

PACK_NAME="Example Research"
PACK_DESC="Generic research pack. Copy this folder, rewrite ROLES.md + TARGETS.md, and you have a fleet for your own topic."

# Subdirectory (inside this pack) where workers write their output files.
OUTPUT_DIR="output"

# Web grounding: when true, workers run a SearXNG search + page fetch and feed
# real sources into the model before it writes (kills hallucinated citations).
# Requires the searxng service (docker compose --profile grounding up).
# When false, workers rely on the agent's own capabilities (e.g. Claude's
# built-in web search).
WEB_GROUNDING="false"

# Space-separated domains to rank FIRST in web-grounding results (high-authority
# sources for your topic). Leave empty for no preference.
SEARCH_PREFERRED_DOMAINS=""

# Space-separated substrings to DROP from web-grounding results (junk for your
# topic). Sensible defaults are always applied on top of this.
SEARCH_BLOCK_DOMAINS=""
