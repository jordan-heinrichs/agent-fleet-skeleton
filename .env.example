# agent-fleet-skeleton — env template
# Copy to .env and customize.

# How often the manager dispatches a new fire (minutes).
TICK_INTERVAL_MINUTES=15

# Number of worker replicas. Skeleton defaults to 2.
FLEET_SIZE=2

# Max time a single worker can spend in `claude --print` per job (minutes).
CLAUDE_MAX_MINUTES=20

# Worker model. Sonnet is the sweet spot for most agent loops.
# Use an Opus model for deeper reasoning, a Haiku model for cheap drafts.
# NOTE: model identifiers change over time. If a worker fast-fails in a few
# seconds right after boot, the model string is probably wrong for your plan.
# Run `claude --help` or check your Anthropic plan for the current identifier
# and update this value.
AGENT_MODEL=claude-sonnet-4-7

# Canary model — small/cheap model used to verify auth + credits before each
# fire. Same note about identifiers applies.
CANARY_MODEL=claude-haiku-4-5-20251001

# Project to operate on. Add new projects under projects/<name>/.
ACTIVE_PROJECT=example-project

# Auto-commit + push every fire? Requires SSH key mounted (see docker-compose).
AGENT_AUTO_PUSH=false

# Git branch to track when auto-push is enabled.
BRANCH=main

# DO NOT SET ANTHROPIC_API_KEY.
# Setting this routes the CLI through API-key billing and bypasses the host's
# Claude Max subscription. The workers authenticate via the mounted ~/.claude
# credentials instead. Leave commented out.
# ANTHROPIC_API_KEY=
