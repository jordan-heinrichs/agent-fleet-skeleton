# agent-fleet-skeleton — env template
# Copy to .env and customize.

# ── Windows only ─────────────────────────────────────────────────────────────
# Set HOST_HOME to your Windows user directory so Docker Compose can resolve
# ~/.claude credential mount paths. Use forward slashes. Do NOT use HOME —
# that variable leaks into containers and breaks their internal paths.
# Linux/Mac: leave this unset, the shell's $HOME resolves automatically.
# HOST_HOME=C:/Users/YourName

# ── Redis ACL credentials ─────────────────────────────────────────────────────
# Manager gets full fleet:* access; workers are scoped to job/result queues only
# and cannot read or write fleet:config. Change before exposing the Docker
# network beyond localhost.
REDIS_MANAGER_PASS=fleet-mgr-secret
REDIS_WORKER_PASS=fleet-wkr-secret

# ── Tick + fleet size ─────────────────────────────────────────────────────────
# How often the manager dispatches a new fire (minutes).
TICK_INTERVAL_MINUTES=15

# Number of worker replicas. Skeleton defaults to 2.
# MAX_FLEET_SIZE: hard ceiling the governor will not exceed when scaling up.
# MIN_TICK_INTERVAL_MINUTES: floor the governor will not drop below.
FLEET_SIZE=2
MAX_FLEET_SIZE=4
MIN_TICK_INTERVAL_MINUTES=5

# Max time a single worker can spend in `claude --print` per job (minutes).
CLAUDE_MAX_MINUTES=20

# ── Provider selection ───────────────────────────────────────────────────────
# AGENT_PROVIDER picks the primary engine the workers use.
#   claude  — Claude Code CLI, rides your Claude Max subscription ($0 per token)
#   ollama  — local models via direct generation, $0 forever; quality scales with your GPU
AGENT_PROVIDER=claude

# Worker model for the primary provider.
#   for claude:  a Claude model string (sonnet is the sweet spot)
#   for ollama:  an Ollama model tag you have pulled, e.g. qwen2.5-coder:14b
# NOTE: model identifiers change over time. Prefer an alias (sonnet/opus/haiku)
# for Claude so it always resolves to a current model. If a worker fast-fails a
# few seconds after boot, the model string is probably wrong for your
# plan/install. Check `claude --help` or `ollama list` and update this.
AGENT_MODEL=sonnet

# Optional fallback provider. If the primary hits a wall (rate-limit / quota /
# fast-fail), the worker retries the SAME job once on this provider before
# sleeping. Set AGENT_FALLBACK=ollama so the fleet keeps running locally when
# Claude Max enters its cooldown window. Leave blank to disable fallback.
AGENT_FALLBACK=
FALLBACK_MODEL=qwen2.5-coder:14b

# Canary model — small/cheap model used to verify the primary provider is alive
# before each fire. For claude this is a Haiku ping; for ollama the canary just
# hits the local server, so any pulled model works here.
CANARY_MODEL=claude-haiku-4-5-20251001

# Where the containers reach a host-run Ollama. Docker Desktop maps
# host.docker.internal to the host automatically. Only used by the ollama
# provider. Install Ollama on the host and `ollama pull <your model>` first.
OLLAMA_API_BASE=http://host.docker.internal:11434

# ── Example presets ──────────────────────────────────────────────────────────
# Pure local, zero cost, no subscription:
#   AGENT_PROVIDER=ollama
#   AGENT_MODEL=qwen2.5-coder:14b
#
# Claude for quality with local fallback so the fleet never stops:
#   AGENT_PROVIDER=claude
#   AGENT_MODEL=sonnet
#   AGENT_FALLBACK=ollama
#   FALLBACK_MODEL=qwen2.5-coder:14b

# ── Topic pack (the plugin that defines your domain) ─────────────────────────
# A pack lives in packs/<name>/ and contains ROLES.md, TARGETS.md, pack.env.
# Swap this to retarget the whole fleet at a different topic. Ships with
# example-research (generic template) and web3-security (real example).
ACTIVE_PACK=example-research

# ── Web grounding + cache ────────────────────────────────────────────────────
# Web grounding is toggled PER PACK (WEB_GROUNDING in the pack's pack.env). When
# a pack enables it, start the search engine with the grounding profile:
#   docker compose --profile grounding up -d --build
# CACHE_TTL: how long (seconds) fetched pages + searches stay in the Redis cache
# before they're eligible for eviction. REDIS_MAXMEMORY caps the cache; stale
# entries get shed (volatile-lru) while the job queue is protected.
CACHE_TTL=86400
REDIS_MAXMEMORY=1gb

# Auto-commit + push every fire? Requires SSH key mounted (see docker-compose).
# ── Monitor dashboard ────────────────────────────────────────────────────────
# Port for the live web dashboard (http://localhost:MONITOR_PORT).
MONITOR_PORT=8080

AGENT_AUTO_PUSH=false

# Git branch to track when auto-push is enabled.
BRANCH=main

# DO NOT SET ANTHROPIC_API_KEY.
# Setting this routes the CLI through API-key billing and bypasses the host's
# Claude Max subscription. The workers authenticate via the mounted ~/.claude
# credentials instead. Leave commented out.
# ANTHROPIC_API_KEY=
